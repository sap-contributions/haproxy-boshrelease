# abort script on failures
set -euxo pipefail

 # Available variables
# $BOSH_COMPILE_TARGET - where this package & spec'd source files are available
# $BOSH_INSTALL_TARGET - where you copy/install files to be included in package

AWSLC_VERSION=1.70.0  # https://github.com/aws/aws-lc/archive/refs/tags/v1.70.0.tar.gz

mkdir -p ${BOSH_INSTALL_TARGET}/bin

tar xzf aws-lc/aws-lc-${AWSLC_VERSION}.tar.gz
pushd aws-lc-${AWSLC_VERSION}
  mkdir -p build
  cd build
  cmake -version
  cmake -DCMAKE_BUILD_TYPE=RelWithDebInfo -DBUILD_SHARED_LIBS=1 -DDISABLE_GO=1 -DDISABLE_PERL=1 \
   -DCMAKE_BUILD_WITH_INSTALL_RPATH=ON -DCMAKE_INSTALL_RPATH=${BUILDSSL_DESTDIR}/lib \
   -DBUILD_TESTING=0 -DCMAKE_INSTALL_PREFIX=${BUILDSSL_DESTDIR} ..
  make -j$(nproc)
  make install
popd

ls -laR .

